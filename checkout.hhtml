<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout - Crescent Beauty Hub</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 font-sans">

  <nav class="bg-white shadow-md sticky top-0 z-50">
    <div class="container mx-auto px-4 py-3 flex justify-between items-center">
      <a href="index.html" class="text-2xl font-bold text-pink-700">Cresent Beauty Hub</a>
      <a href="cart.html" class="text-gray-600 hover:text-pink-600 text-sm">← Back to Cart</a>
    </div>
  </nav>

  <div class="container mx-auto px-4 py-8 max-w-3xl">
    <h1 class="text-3xl font-bold text-gray-800 mb-6">Checkout</h1>

    <!-- Order Form -->
    <form id="checkout-form" class="bg-white p-6 rounded-lg shadow-md">
      <div class="grid grid-cols-1 gap-4">
        <input type="text" id="fullName" placeholder="Full Name" required class="border p-3 rounded focus:ring-pink-500 focus:border-pink-500">
        <input type="email" id="email" placeholder="Email Address" required class="border p-3 rounded focus:ring-pink-500 focus:border-pink-500">
        <input type="tel" id="phone" placeholder="Phone Number" required class="border p-3 rounded focus:ring-pink-500 focus:border-pink-500">
        <textarea id="address" placeholder="Delivery Address (with landmark)" required class="border p-3 rounded focus:ring-pink-500 focus:border-pink-500" rows="3"></textarea>
      </div>

      <!-- Bank Details (from Firebase) -->
      <div class="mt-6 p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
        <h3 class="font-bold text-gray-700">💳 Bank Transfer Details</h3>
        <p class="text-sm">Transfer the <strong>exact total amount</strong> below to this account:</p>
        <div class="mt-2 p-3 bg-white rounded border">
          <p><strong>Bank:</strong> <span id="bank-name">Loading...</span></p>
          <p><strong>Account Name:</strong> <span id="account-name">Loading...</span></p>
          <p><strong>Account Number:</strong> <span id="account-number" class="text-lg font-mono">Loading...</span></p>
        </div>
      </div>

      <!-- Receipt Upload -->
      <div class="mt-4">
        <label class="block text-sm font-medium text-gray-700">Upload Payment Receipt (Screenshot/PDF)</label>
        <input type="file" id="receipt" accept="image/*,.pdf" required class="mt-1 block w-full border p-2 rounded">
      </div>

      <!-- Order Summary -->
      <div class="mt-6 p-4 bg-gray-50 rounded-lg">
        <h4 class="font-bold">Order Summary</h4>
        <div id="order-summary-items" class="text-sm mt-2"></div>
        <div class="flex justify-between font-bold text-lg mt-3 pt-3 border-t">
          <span>Total:</span>
          <span id="checkout-total" class="text-pink-600">₦0</span>
        </div>
      </div>

      <button type="submit" class="mt-6 w-full bg-pink-600 hover:bg-pink-700 text-white py-3 rounded-lg transition font-semibold">Place Order</button>
    </form>

    <!-- Success / WhatsApp Section (hidden initially) -->
    <div id="success-box" class="hidden bg-green-50 border border-green-200 p-6 rounded-lg text-center mt-6">
      <h2 class="text-2xl font-bold text-green-700">✅ Order Placed Successfully!</h2>
      <p class="text-gray-700 mt-2">Your Order ID: <strong id="order-id-display">#CR-001</strong></p>
      <p class="text-sm text-gray-600 mt-1">Please send your payment receipt to us on WhatsApp to confirm your order.</p>
      <a id="whatsapp-btn" href="#" target="_blank" class="mt-4 inline-block bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-full shadow-lg transition text-lg font-semibold">
        📲 Send Receipt on WhatsApp
      </a>
      <p class="text-xs text-gray-500 mt-4">Don't forget to mention your Order ID in the message.</p>
      <a href="index.html" class="mt-4 inline-block text-pink-600 underline">Continue Shopping</a>
    </div>
  </div>

  <!-- ==================== JAVASCRIPT ==================== -->
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
  <script>
    // 1. CONFIG
    const firebaseConfig = {
      apiKey: "YOUR_API_KEY",
      authDomain: "YOUR_PROJECT.firebaseapp.com",
      databaseURL: "https://YOUR_PROJECT-default-rtdb.firebaseio.com",
      projectId: "YOUR_PROJECT",
      storageBucket: "YOUR_PROJECT.appspot.com",
      messagingSenderId: "YOUR_SENDER_ID",
      appId: "YOUR_APP_ID"
    };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();

    const IK_PUBLIC_KEY = "your_imagekit_public_key";
    const WHATSAPP_NUMBER = "2347038721342"; // Without '+'

    // 2. LOAD BANK DETAILS
    db.ref('settings/bankDetails').on('value', (snap) => {
      const bank = snap.val();
      if (bank) {
        document.getElementById('bank-name').textContent = bank.bankName || 'N/A';
        document.getElementById('account-name').textContent = bank.accountName || 'N/A';
        document.getElementById('account-number').textContent = bank.accountNumber || 'N/A';
      }
    });

    // 3. LOAD CART & DISPLAY SUMMARY
    function loadCartSummary() {
      const cart = JSON.parse(localStorage.getItem('cart')) || [];
      const container = document.getElementById('order-summary-items');
      const totalSpan = document.getElementById('checkout-total');
      let total = 0;

      if (cart.length === 0) {
        container.innerHTML = '<p class="text-red-500">Your cart is empty. Please add items.</p>';
        totalSpan.textContent = '₦0';
        return;
      }

      container.innerHTML = cart.map(item => `
        <div class="flex justify-between py-1">
          <span>${item.name} x${item.qty}</span>
          <span>₦${(item.price * item.qty).toLocaleString()}</span>
        </div>
      `).join('');

      total = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
      totalSpan.textContent = `₦${total.toLocaleString()}`;
    }
    loadCartSummary();

    // 4. UPLOAD TO IMAGEKIT
    async function uploadToImageKit(file, folder) {
      const formData = new FormData();
      formData.append("file", file);
      formData.append("fileName", file.name);
      formData.append("folder", folder);

      const response = await fetch("https://upload.imagekit.io/api/v1/files/upload", {
        method: "POST",
        headers: {
          "Authorization": `Basic ${btoa(IK_PUBLIC_KEY + ":")}`
        },
        body: formData
      });
      const data = await response.json();
      if (!response.ok) throw new Error(data.message || 'Upload failed');
      return data.url;
    }

    // 5. PLACE ORDER
    document.getElementById('checkout-form').addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = document.getElementById('fullName').value.trim();
      const email = document.getElementById('email').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const address = document.getElementById('address').value.trim();
      const receiptFile = document.getElementById('receipt').files[0];

      if (!receiptFile) {
        alert('Please upload your payment receipt.');
        return;
      }

      const cart = JSON.parse(localStorage.getItem('cart')) || [];
      if (cart.length === 0) {
        alert('Your cart is empty.');
        return;
      }

      try {
        // Upload receipt
        const receiptUrl = await uploadToImageKit(receiptFile, "/receipts");

        // Calculate total
        const total = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);

        // Push to Firebase
        const newOrderRef = db.ref('orders').push();
        const orderId = `CR-${Date.now().toString().slice(-6)}`;

        await newOrderRef.set({
          orderId: orderId,
          customerName: name,
          email: email,
          phone: phone,
          address: address,
          items: cart,
          totalAmount: total,
          paymentStatus: "pending",
          receiptUrl: receiptUrl,
          placedAt: firebase.database.ServerValue.TIMESTAMP
        });

        // Clear cart
        localStorage.removeItem('cart');

        // Show success & WhatsApp
        document.getElementById('checkout-form').style.display = 'none';
        document.getElementById('success-box').classList.remove('hidden');
        document.getElementById('order-id-display').textContent = `#${orderId}`;

        const waMessage = `Hello Cresent Beauty Hub, I have paid for Order #${orderId} via Bank Transfer. Please check my receipt on your admin dashboard.`;
        const waLink = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(waMessage)}`;
        document.getElementById('whatsapp-btn').href = waLink;

      } catch (error) {
        alert('Error placing order: ' + error.message);
        console.error(error);
      }
    });
  </script>
</body>
</html>
